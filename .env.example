# Optional ports.
PORT=4173
API_PORT=4180
API_HOST=127.0.0.1

# Comma-separated frontend origins allowed to call the API.
# Production example: https://your-project.vercel.app,https://www.example.com
API_ALLOWED_ORIGINS=http://127.0.0.1:4173,http://localhost:4173

# Frontend build-time API base URL. Keep empty for local static preview; it will use http://127.0.0.1:4180.
MARKET_API_BASE_URL=

# API market-data cache directory. Use a persistent disk path in production.
MARKET_DATA_DIR=storage/market-data

# Long-term market-data cache. In production, prefer Supabase PostgreSQL over Render Disk or /tmp.
DATABASE_URL=
DATABASE_SSL=true
